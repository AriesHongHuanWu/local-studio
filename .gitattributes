# Normalize text line endings across platforms
* text=auto eol=lf

# Windows scripts keep CRLF
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary assets (fonts, icons) — never diff/normalize
*.woff2 binary
*.woff  binary
*.ttf   binary
*.otf   binary
*.png   binary
*.jpg   binary
*.ico   binary
*.icns  binary
*.pt    binary
*.onnx  binary
