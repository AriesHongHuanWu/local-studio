# ── Python backend ──────────────────────────────────────────────
backend/.venv/
backend/venv/
**/__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# Model weights / inference caches (multi-GB — downloaded on first run)
model/
backend/models/
backend/out/
*.pt
*.onnx
*.ckpt
.cache/

# Runtime scratch
backend/tmp/
backend/jobs/
*.wav
*.flac
*.lrc
*.srt
*.ass

# ── Frontend (React + Vite) ─────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo
frontend/build-override.json
# package-lock omitted: npm's platform-specific optional deps (rollup/esbuild)
# make a Windows-generated lock fail `npm ci` on Linux. Use `npm install`.
package-lock.json

# ── Tauri desktop shell (Rust) ──────────────────────────────────
frontend/src-tauri/target/
frontend/src-tauri/gen/

# ── Bundled portable Python (fetched at build time, tens of MB) ──
# scripts/fetch-portable-python.* populates this; CI runs it before `tauri build`.
# Keep the .gitkeep so the tauri.conf resource glob always matches on a fresh
# clone (build never breaks); ignore the heavy interpreter itself.
frontend/src-tauri/resources/python/*
!frontend/src-tauri/resources/python/.gitkeep

# ── Updater signing keys (SECRET — never commit) ────────────────
.tauri-keys/
*.key
# NOTE: Cargo.lock IS committed (this is an application — reproducible builds)

# ── Local-only tooling / internal (not published) ───────────────
.claude/
marketing/

# ── Editor / OS ─────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
